RUN__HOST=0.0.0.0
RUN__PORT=8000

POSTGRES_DB=foodize
POSTGRES_USER=foodize_user
POSTGRES_PASSWORD=postgres123

DB__URL=postgresql+asyncpg://foodize_user:postgres123@pg:5432/foodize
DB__ECHO=false
DB__ECHO_POOL=false
DB__POOL_SIZE=50
DB__MAX_OVERFLOW=10

REDIS__URL=redis://redis:6379/0

RABBITMQ_USER=foodize
RABBITMQ_PASS=foodize
RABBITMQ__URL=amqp://foodize:foodize@rabbitmq:5672/foodize
RABBITMQ_VHOST=foodize

LOGS__LEVEL=INFO
LOGS__SENTRY_DSN=
LOGS__ENVIRONMENT=development

CORS__ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

AUTH__ACCESS_TOKEN_LIFETIME_SECONDS=1800
AUTH__REFRESH_TOKEN_LIFETIME_SECONDS=2592000

# Telegram Bot (получить токен у @BotFather)
BOT_TOKEN=
MINI_APP_URL=
BOT_USERNAME=
TELEGRAM__BOT_API_SECRET=
BOT_MODE=polling
# Для webhook-режима:
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=

# Backend Telegram config
TELEGRAM__BOT_TOKEN=${BOT_TOKEN}
TELEGRAM__MINI_APP_URL=${MINI_APP_URL}

# Frontend build-time URLs for QR/share links
VITE_WEB_URL=http://localhost:5173
VITE_MINI_APP_URL=${MINI_APP_URL}
VITE_BOT_USERNAME=${BOT_USERNAME}

# ── LLM provider (AI advisor + order agent) ────────────────────────────────
# Pick ONE provider via LLM__PROVIDER. OpenRouter is OpenAI-compatible.
LLM__PROVIDER=openai
LLM__OPENAI_API_KEY=sk-or-...
LLM__OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM__OPENAI_MODEL=cohere/north-mini-code:free
# Anthropic (direct): LLM__PROVIDER=anthropic, LLM__ANTHROPIC_API_KEY=sk-ant-...
# Ollama (local):     LLM__PROVIDER=ollama,  LLM__OLLAMA_MODEL=qwen2.5

# Embeddings for semantic menu search — local Ollama bge-m3 (`ollama pull bge-m3`).
# If unreachable, search falls back to keyword matching automatically.
LLM__EMBEDDINGS_ENABLED=true
LLM__EMBEDDING_BASE_URL=http://localhost:11434/v1
LLM__EMBEDDING_MODEL=bge-m3
