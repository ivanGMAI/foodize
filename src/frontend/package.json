{
  "name": "foodize",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "api:types": "openapi-typescript ../../openapi/foodize.openapi.json -o src/services/generated/schema.ts",
    "api:client": "node ../../tools/generate_openapi_client.mjs --schema=../../openapi/foodize.openapi.json --output=src/services/generated/client.ts --api-import=../api",
    "api:format": "prettier --write \"src/services/generated/*.ts\"",
    "api:generate": "npm run api:types && npm run api:client && npm run api:format",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "axios": "^1.15.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.0.0",
    "axios-mock-adapter": "^2.1.0",
    "baseline-browser-mapping": "^2.10.20",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.0.0",
    "msw": "^2.0.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.6.2",
    "vite": "^7.2.4",
    "vitest": "^3.0.0"
  }
}
